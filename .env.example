# Vault Enterprise Cloud Edition
# Environment Variables

# Groww API Credentials
GROWW_API_KEY=your_api_key_here
GROWW_API_SECRET=your_api_secret_here

# Discord Bot
DISCORD_TOKEN=your_discord_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# URLs for Frontend (used during Next.js build)
NEXT_PUBLIC_API_URL=http://YOUR_VPS_PUBLIC_IP:8000
NEXT_PUBLIC_WS_URL=ws://YOUR_VPS_PUBLIC_IP:8000/ws
NEXT_PUBLIC_BOOTUP_WS_URL=ws://YOUR_VPS_PUBLIC_IP:8001
